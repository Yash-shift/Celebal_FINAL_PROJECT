{
  "datasets": [
    {
      "name": "0420683d",
      "displayName": "KPI_data",
      "config": {
        "version": "1.1",
        "source": "SELECT *\r\nFROM workspace.gold.kpi_dashboard",
        "dimensions": [
          {
            "name": "total_patients",
            "expr": "source.total_patients",
            "displayName": "Total Patients"
          },
          {
            "name": "total_doctors",
            "expr": "source.total_doctors",
            "displayName": "Total Doctors"
          },
          {
            "name": "total_appointments",
            "expr": "source.total_appointments",
            "displayName": "Total Appointments"
          },
          {
            "name": "completed",
            "expr": "source.completed",
            "displayName": "Completed"
          },
          {
            "name": "cancelled",
            "expr": "source.cancelled",
            "displayName": "Cancelled"
          },
          {
            "name": "no_show",
            "expr": "source.no_show",
            "displayName": "No Show"
          },
          {
            "name": "scheduled",
            "expr": "source.scheduled",
            "displayName": "Scheduled"
          },
          {
            "name": "total_revenue",
            "expr": "source.total_revenue",
            "displayName": "Total Revenue"
          },
          {
            "name": "average_bill",
            "expr": "source.average_bill",
            "displayName": "Average Bill"
          },
          {
            "name": "completion_rate",
            "expr": "source.completion_rate",
            "displayName": "Completion Rate"
          },
          {
            "name": "cancel_rate",
            "expr": "source.cancel_rate",
            "displayName": "Cancel Rate"
          },
          {
            "name": "no_show_rate",
            "expr": "source.no_show_rate",
            "displayName": "No Show Rate"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "name": "Total Patient",
            "expr": "SUM(total_patients)",
            "displayName": "Total Patient"
          },
          {
            "name": "Total Doctors",
            "expr": "SUM(total_doctors)",
            "displayName": "Total Doctors"
          },
          {
            "name": "Total Appointments",
            "expr": "SUM(total_appointments)",
            "displayName": "Total Appointments"
          },
          {
            "name": "total revenue",
            "expr": "SUM(total_revenue)",
            "displayName": "total revenue"
          },
          {
            "name": "average bill",
            "expr": "AVG(average_bill)",
            "displayName": "average bill"
          }
        ]
      }
    },
