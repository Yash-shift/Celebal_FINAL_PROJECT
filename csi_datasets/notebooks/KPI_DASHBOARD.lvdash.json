    {
      "name": "appointment_status",
      "displayName": "Appointment Status Breakdown",
      "config": {
        "version": "1.1",
        "source": "SELECT 'Completed' AS status, completed AS count\nFROM workspace.gold.kpi_dashboard\nUNION ALL\nSELECT 'Cancelled' AS status, cancelled AS count\nFROM workspace.gold.kpi_dashboard\nUNION ALL\nSELECT 'No Show' AS status, no_show AS count\nFROM workspace.gold.kpi_dashboard\nUNION ALL\nSELECT 'Scheduled' AS status, scheduled AS count\nFROM workspace.gold.kpi_dashboard\n",
        "dimensions": [
          {
            "name": "status",
            "expr": "source.status",
            "displayName": "Status"
          }
        ],
        "measures": [
          {
            "name": "appointment_count",
            "expr": "SUM(count)",
            "displayName": "Appointment Count"
          }
        ]
      }
    }
